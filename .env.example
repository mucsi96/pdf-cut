# Copy to .env and fill in. Passed to the container via: podman run --env-file .env
# Punch-hole inpainting runs LOCALLY (OpenCV + LaMa, bundled in the image) and
# needs no API key.
# Gemini: per-page vision QA + color cover recreation
GEMINI_API_KEY=
# Anthropic: optional vision QA fallback (--vision-provider anthropic)
ANTHROPIC_API_KEY=

# Optional model overrides
#PDFCUT_VISION_MODEL=gemini-2.5-flash
#PDFCUT_COVER_MODEL=gemini-3-pro-image-preview
#PDFCUT_ANTHROPIC_VISION_MODEL=claude-sonnet-4-6
# Optional: torch device for LaMa (default cpu)
#PDFCUT_TORCH_DEVICE=cpu
