# Google AI Studio API key, used by the `cover` stage and the markdown stage's
# figure recreation (Gemini image generation).
# Get one at https://aistudio.google.com/apikey — then: cp .env.example .env
GEMINI_API_KEY=

# Anthropic API key, used by the markdown stage for page transcription
# (markdown.model defaults to claude-opus-4-8).
# Get one at https://platform.claude.com/
ANTHROPIC_API_KEY=
