# Copy to .env and fill in. Passed to the container via: podman run --env-file .env
# Gemini: per-page vision analysis + color cover recreation
GEMINI_API_KEY=
# OpenAI: gpt-image-1 mask-based punch-hole inpainting
OPENAI_API_KEY=
# Anthropic: optional vision fallback (--vision-provider anthropic)
ANTHROPIC_API_KEY=

# Optional model overrides
#PDFCUT_VISION_MODEL=gemini-2.5-flash
#PDFCUT_COVER_MODEL=gemini-3-pro-image-preview
#PDFCUT_INPAINT_MODEL=gpt-image-1
#PDFCUT_ANTHROPIC_VISION_MODEL=claude-sonnet-4-6
